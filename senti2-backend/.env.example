APP_NAME=Senti2
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:4200

LOG_CHANNEL=stack

DB_CONNECTION=sqlite

# Supabase
SUPABASE_URL=
# Clave pública (anon) para Auth/verificación JWT
SUPABASE_ANON_KEY=
# Clave privada (service_role) para llamadas REST desde el servidor
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Mail (formulario de contacto)
MAIL_MAILER=log
MAIL_CONTACT_TO=senti2soporte@gmail.com

# Broadcasting / Reverb
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=senti2
REVERB_APP_KEY=senti2-key
REVERB_APP_SECRET=senti2-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http